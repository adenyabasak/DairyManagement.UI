@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .dairy-hero {
        min-height: 520px;
        border-radius: 28px;
        overflow: hidden;
        position: relative;
        background: linear-gradient(120deg, rgba(20, 35, 70, .78), rgba(48, 112, 141, .35)), url('https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1600&q=80');
        background-size: cover;
        background-position: center;
        box-shadow: 0 25px 60px rgba(0,0,0,.18);
    }

    .dairy-hero-content {
        position: relative;
        z-index: 2;
        padding: 70px 60px;
        color: white;
        max-width: 760px;
    }

    .dairy-badge {
        display: inline-block;
        padding: 10px 18px;
        border-radius: 999px;
        background: rgba(255,255,255,.18);
        backdrop-filter: blur(10px);
        font-weight: 700;
        letter-spacing: .5px;
        margin-bottom: 18px;
    }

    .dairy-title {
        font-size: 52px;
        font-weight: 900;
        line-height: 1.08;
        margin-bottom: 18px;
    }

    .dairy-text {
        font-size: 18px;
        opacity: .95;
        line-height: 1.8;
        margin-bottom: 30px;
    }

    .dairy-buttons a {
        border-radius: 14px;
        padding: 14px 24px;
        font-weight: 700;
        margin-right: 10px;
    }

    .glass-panel {
        margin-top: -70px;
        position: relative;
        z-index: 5;
    }

    .feature-card {
        border: 0;
        border-radius: 24px;
        background: rgba(255,255,255,.92);
        backdrop-filter: blur(14px);
        box-shadow: 0 20px 45px rgba(34, 47, 62, .14);
        transition: .3s;
        min-height: 210px;
    }

        .feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 28px 55px rgba(34, 47, 62, .2);
        }

    .feature-icon {
        width: 62px;
        height: 62px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: white;
        margin-bottom: 18px;
    }

    .icon-blue {
        background: linear-gradient(135deg, #4e73df, #224abe);
    }

    .icon-green {
        background: linear-gradient(135deg, #1cc88a, #0f9f6e);
    }

    .icon-orange {
        background: linear-gradient(135deg, #f6c23e, #e09b12);
    }

    .icon-purple {
        background: linear-gradient(135deg, #6f42c1, #4b2e83);
    }

    .feature-card h5 {
        font-weight: 800;
        color: #2e3a59;
    }

    .feature-card p {
        color: #6c757d;
        font-size: 14px;
        line-height: 1.7;
    }

    .farm-strip {
        border-radius: 24px;
        background: linear-gradient(135deg, #f8fbff, #edf7f3);
        box-shadow: 0 18px 40px rgba(0,0,0,.08);
        padding: 30px;
        margin-top: 35px;
    }

    .mini-image {
        height: 190px;
        border-radius: 22px;
        background-size: cover;
        background-position: center;
        box-shadow: inset 0 0 0 2000px rgba(0,0,0,.08);
    }

    @@media (max-width: 768px) {
        .dairy-hero-content {
            padding: 45px 28px;
        }

        .dairy-title {
            font-size: 36px;
        }

        .glass-panel {
            margin-top: 25px;
        }
    }
</style>

<div class="dairy-hero mb-5">

    <div class="dairy-hero-content">
        <span class="dairy-badge">
            🐄 Premium Dairy Farm
        </span>

        <h1 class="dairy-title">
            Süt Ürünleri Yönetim Sistemine Hoş Geldiniz
        </h1>

        <p class="dairy-text">
            Doğal üretim, kaliteli ürün takibi ve modern işletme yönetimini tek bir panelde birleştiren
            şık ve kullanışlı yönetim ekranı.
        </p>

        <div class="dairy-buttons">
            <a href="/Product" class="btn btn-light">
                <i class="fas fa-box"></i> Ürünleri Gör
            </a>

            <a href="/CustomerOrder" class="btn btn-outline-light">
                <i class="fas fa-shopping-cart"></i> Siparişlere Git
            </a>
        </div>
    </div>

</div>

<div class="glass-panel">
    <div class="row">

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card feature-card p-4">
                <div class="feature-icon icon-blue">
                    <i class="fas fa-list"></i>
                </div>
                <h5>Kategori Yönetimi</h5>
                <p>Süt, yoğurt, peynir ve diğer ürün gruplarını düzenli şekilde yönetin.</p>
                <a href="/Category" class="btn btn-sm btn-primary rounded-pill">Kategorilere Git</a>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card feature-card p-4">
                <div class="feature-icon icon-green">
                    <i class="fas fa-cheese"></i>
                </div>
                <h5>Ürün Yönetimi</h5>
                <p>Ürün adı, fiyat, stok ve kategori bilgilerini kolayca takip edin.</p>
                <a href="/Product" class="btn btn-sm btn-success rounded-pill">Ürünlere Git</a>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card feature-card p-4">
                <div class="feature-icon icon-orange">
                    <i class="fas fa-truck"></i>
                </div>
                <h5>Tedarikçiler</h5>
                <p>Çiftlikler, üreticiler ve tedarikçi iletişim bilgilerini kontrol edin.</p>
                <a href="/Supplier" class="btn btn-sm btn-warning rounded-pill text-white">Tedarikçilere Git</a>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card feature-card p-4">
                <div class="feature-icon icon-purple">
                    <i class="fas fa-shopping-basket"></i>
                </div>
                <h5>Siparişler</h5>
                <p>Müşteri siparişlerini, adetleri ve toplam tutarları tek ekrandan yönetin.</p>
                <a href="/CustomerOrder" class="btn btn-sm btn-dark rounded-pill">Siparişlere Git</a>
            </div>
        </div>

    </div>
</div>

<div class="farm-strip">
    <div class="row align-items-center">

        <div class="col-lg-5 mb-4 mb-lg-0">
            <h3 class="font-weight-bold text-gray-800">
                Modern Çiftlik, Güçlü Yönetim
            </h3>

            <p class="text-muted mt-3">
                Bu panel; süt ürünleri işletmeleri için sade, hızlı ve profesyonel bir yönetim deneyimi sunar.
                Ürün, tedarikçi ve sipariş süreçleri tek merkezden kontrol edilir.
            </p>

            <a href="/Report" class="btn btn-primary rounded-pill mt-2">
                <i class="fas fa-chart-line"></i> Raporlar Sayfasına Git
            </a>
        </div>

        <div class="col-lg-7">
            <div class="row">

                <div class="col-md-6 mb-3">
                    <div class="mini-image"
                         style="background-image:url('https://images.unsplash.com/photo-1484557985045-edf25e08da73?auto=format&fit=crop&w=900&q=80');">
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <div class="mini-image"
                         style="background-image:url('https://images.unsplash.com/photo-1527153857715-3908f2bae5e8?auto=format&fit=crop&w=900&q=80');">
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>