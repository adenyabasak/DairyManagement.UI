@model DairyManagement.Entity.Category

@{
    ViewData["Title"] = "Kategori Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Kategori Ekle</h2>

<form method="post">

    <div class="mb-3">
        <label class="form-label">Kategori Adı</label>

        <input asp-for="CategoryName"
               class="form-control" />
    </div>

    <button class="btn btn-success">
        Kaydet
    </button>

    <a href="/Category"
       class="btn btn-secondary">
        Geri Dön
    </a>

</form>